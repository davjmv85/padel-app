rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && userDoc().role == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && userDoc().role in ['admin', 'collaborator'];
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      // Staff can update anything; players can only update currentRegistrations (via inscription)
      allow update: if isAuthenticated() && (
        isStaff() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentRegistrations', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    // Registrations collection
    match /registrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isStaff();
    }

    // Event pairs collection
    match /event_pairs/{pairId} {
      allow read: if isAuthenticated();
      allow create, delete: if isStaff();
      // Staff: full update. Owner: only their cached name in their slot.
      allow update: if isStaff() ||
        (isAuthenticated() &&
         resource.data.player1Id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['player1Name', 'updatedAt'])) ||
        (isAuthenticated() &&
         resource.data.player2Id == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['player2Name', 'updatedAt']));
    }

    // Matches collection
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    // Rankings collection
    match /rankings/{rankingId} {
      allow read: if isAuthenticated();
      // Staff: full write. Owner: only their own userName on their ranking doc.
      allow create, delete: if isStaff();
      allow update: if isStaff() ||
        (isAuthenticated() &&
         isOwner(rankingId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userName', 'updatedAt']));
    }

    // Event groups collection (americano)
    match /event_groups/{groupId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    // Waitlist collection
    match /waitlist/{waitlistId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Any auth user may flip notified after a spot frees up (runs from the client
      // that cancels the registration, not necessarily the waitlisted user).
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notified', 'notifiedAt']);
      allow delete: if isStaff();
    }
  }
}
