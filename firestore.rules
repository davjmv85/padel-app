rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'collaborator');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Events collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Registrations collection
    match /registrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isStaff() ||
        (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled')
      );
    }

    // Event pairs collection
    match /event_pairs/{pairId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    // Matches collection
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff();
    }

    // Rankings collection
    match /rankings/{rankingId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions can write
    }

    // Waitlist collection
    match /waitlist/{waitlistId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update, delete: if false; // Only Cloud Functions
    }
  }
}
